---
import Default from '@astrojs/starlight/components/Sidebar.astro';
import Search from '@astrojs/starlight/components/Search.astro';
---

{
  /* Search lives here rather than in the header, which holds the section nav
  (see Header.astro). Splash pages render no sidebar, so the header mounts a
  fallback search there - exactly one instance exists per page. */
}
<div class="sidebar-search print:hidden">
  <Search />
</div>

<Default><slot /></Default>

<script>
  // Sidebar boot, in a deliberate order so the reveal never animates:
  // 1. Expand any folded ancestor group of the current page - Starlight's
  //    restore point may have re-closed the group the server rendered open.
  // 2. Scroll the current item into view (no-op when already visible).
  // 3. Arm the collapse animation (custom.css transitions wait for
  //    .sl-sidebar-loaded, else every group animates shut on navigation).
  document.addEventListener('DOMContentLoaded', () => {
    requestAnimationFrame(() => {
      const current = document.querySelector('.sidebar-content a[aria-current="page"]');
      if (current) {
        let group = current.closest('details');
        while (group) {
          group.open = true;
          group = group.parentElement?.closest('details') ?? null;
        }
        current.scrollIntoView({ block: 'nearest' });
      }
      document.querySelector('.sidebar-pane')?.classList.add('sl-sidebar-loaded');
    });
  });
</script>

<style>
  .sidebar-search {
    margin-block-end: 0.5rem;
  }
</style>
